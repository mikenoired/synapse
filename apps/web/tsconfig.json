{
	"extends": "@synapse/tsconfig/nextjs.json",
	"compilerOptions": {
		"experimentalDecorators": true,
		"ignoreDeprecations": "6.0",
		"baseUrl": ".",
		"paths": {
			"@/*": ["src/*"]
		},
		"strictNullChecks": true
	},
	"include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
	"exclude": ["node_modules"]
}
